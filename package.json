{
  "name": "telegram-gantt-bot",
  "version": "0.1.0",
  "description": "Telegram Interactive Gantt & PM Bot – Modular Monolith",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "tsx watch --env-file .env src/app.ts",
    "build": "tsc && vite build --config webapp/vite.config.ts",
    "start": "node dist/app.js",
    "db:generate": "prisma generate",
    "db:migrate:dev": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:fitness": "vitest run tests/fitness",
    "lint": "eslint src/ tests/",
    "lint:boundaries": "eslint src/ --rule '{\"no-restricted-imports\": \"error\"}'",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/static": "^8.0.0",
    "@grammyjs/conversations": "^2.0.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.2.0",
    "fastify": "^5.8.0",
    "grammy": "^1.41.0",
    "pg": "^8.20.0",
    "pino": "^10.0.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "dotenv": "^17.3.1",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9.0.0",
    "eslint-plugin-import-x": "^4.0.0",
    "prisma": "^7.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
